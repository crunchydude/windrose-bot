# ─── Required ───────────────────────────────────────────────
# Telegram bot token from @BotFather
BOT_TOKEN=

# Telegram user ID of the administrator (numeric).
# To find: send any message to https://t.me/Getmyid_bot
ADMIN_ID=

# ─── Optional ───────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to start the server
# and view online status. Admin always has full rights.
# Example: TRUSTED_USERS=123456789,987654321
TRUSTED_USERS=

# Path to docker-compose.yml directory (default: /opt/windrose)
COMPOSE_DIR=/opt/windrose

# Number of log lines shown in /logs (default: 40)
LOG_LINES=40

# Server max-players cap, used in UI display "2/4" (default: 4)
# Should match MAX_PLAYERS in your Windrose server .env
MAX_PLAYERS=4

# Notify admin when a trusted user starts the server (default: true)
NOTIFY_ADMIN_ON_START=true

# Verbose log-watcher output for diagnosing parser issues (default: false)
# When true, the bot logs the first 20 raw lines after each watcher start
# and every detected event at DEBUG level — visible in journalctl.
LOG_WATCHER_DEBUG=false
